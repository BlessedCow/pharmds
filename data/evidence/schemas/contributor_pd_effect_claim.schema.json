{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contributor_pd_effect_claim.schema.json",
  "title": "Contributor PD Effect Claim",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "claim_type",
    "subject",
    "predicate",
    "object",
    "evidence",
    "contributor",
    "review"
  ],
  "properties": {
    "claim_type": {
      "const": "pd_effect"
    },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entity_type",
        "id"
      ],
      "properties": {
        "entity_type": {
          "const": "drug"
        },
        "id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9_]+$"
        }
      }
    },
    "predicate": {
      "const": "has_pd_effect"
    },
    "object": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "effect_id"
      ],
      "properties": {
        "effect_id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9_]+$"
        }
      }
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "source_id",
          "evidence_type",
          "supports_claim",
          "confidence",
          "notes"
        ],
        "properties": {
          "source_id": {
            "type": "string",
            "minLength": 1,
            "pattern": "^source_[A-Za-z0-9_]+$"
          },
          "evidence_type": {
            "type": "string",
            "minLength": 1
          },
          "supports_claim": {
            "type": "boolean"
          },
          "confidence": {
            "enum": [
              "low",
              "moderate",
              "high",
              "uncertain"
            ]
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "contributor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "role",
        "submitted_at"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9_]+$"
        },
        "role": {
          "type": "string",
          "minLength": 1
        },
        "submitted_at": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status"
      ],
      "properties": {
        "status": {
          "const": "submitted"
        }
      }
    }
  }
}